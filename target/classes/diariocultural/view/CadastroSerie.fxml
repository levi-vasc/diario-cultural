<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="diariocultural.controller.CadastroSerieController">
   <children>
      <GridPane hgap="10.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="135.0" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="184.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="135.0" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="184.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Título:" GridPane.halignment="RIGHT" />
            <TextField fx:id="titulo" GridPane.columnIndex="1" />
            <Label layoutX="10.0" layoutY="202.0" text="Gênero:" GridPane.columnIndex="2" GridPane.halignment="RIGHT" />
            <Label layoutX="310.0" layoutY="201.0" text="Lançamento:" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
            <TextField fx:id="ano" layoutX="460.0" layoutY="197.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label layoutX="10.0" layoutY="335.0" text="Encerramento:" GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
            <TextField fx:id="encerramento" layoutX="160.0" layoutY="331.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            <Label layoutX="361.0" layoutY="201.0" text="Elenco:" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
            <TextField fx:id="elenco" layoutX="160.0" layoutY="197.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label layoutX="64.0" layoutY="335.0" text="Título original" GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
            <TextField fx:id="titulo_original" layoutX="160.0" layoutY="331.0" GridPane.columnIndex="3" GridPane.rowIndex="2" />
            <Label layoutX="366.0" layoutY="252.0" text="Onde assistir:" GridPane.halignment="RIGHT" GridPane.rowIndex="3" />
            <TextField fx:id="onde_assistir" layoutX="460.0" layoutY="248.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Button fx:id="salvar_serie" mnemonicParsing="false" onAction="#handleSalvarSerie" styleClass="save-button" stylesheets="@cadastrostyle.css" text="Cadastrar Série" GridPane.columnIndex="3" GridPane.rowIndex="3" />
            <StackPane prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="3">
               <children>
                  <TextField fx:id="txt_genero" />
                  <Button fx:id="genero" mnemonicParsing="false" styleClass="arrow-button" stylesheets="@cadastrostyle.css" text="v" StackPane.alignment="CENTER_RIGHT" />
               </children>
            </StackPane>
            <VBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                     <children>
                        <Label text="Ano:" />
                        <TextField fx:id="anoTemporada" prefHeight="26.0" prefWidth="125.0" />
                     </children>
                  </HBox>
                  <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                     <children>
                        <Label text="Nº Eps:" />
                        <TextField fx:id="numEpisodiosTemporada" prefHeight="26.0" prefWidth="40.0" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox spacing="10.0" GridPane.rowIndex="5">
               <children>
                  <Label text="Temporada" />
                  <HBox prefHeight="32.0" prefWidth="90.0">
                     <children>
                        <Label text="Nº " />
                        <TextField fx:id="numTemporada" prefHeight="26.0" prefWidth="40.0" />
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
            <Button fx:id="addTemporadaButton" mnemonicParsing="false" onAction="#handleAddTemporada" styleClass="save-button" stylesheets="@cadastrostyle.css" text="Add temp." GridPane.columnIndex="3" GridPane.rowIndex="5" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </GridPane>
   </children>
</AnchorPane>
