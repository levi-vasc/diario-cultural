<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="content-area" stylesheets="@buscastyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="diariocultural.controller.BuscaSerieController">
    <children>
        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Label text="Busca:" />
                <TextField fx:id="field_busca" />
                <Button fx:id="bt_busca" mnemonicParsing="false" onAction="#handleBuscaSerie" styleClass="ok-button" text="Ok" />
                <Label text="Termos disponíveis: título, ator, gênero, ano" />
            </children>
         <padding>
            <Insets left="20.0" top="10.0" />
         </padding>
        </HBox>
        <TableView fx:id="tabelaSeries" layoutX="83.0" layoutY="81.0" prefHeight="200.0" prefWidth="640.0">
            <columns>
                <TableColumn fx:id="tituloColumn" prefWidth="75.0" text="Título" />
                <TableColumn fx:id="generoColumn" prefWidth="75.0" text="Gênero" />
                <TableColumn fx:id="anoColumn" prefWidth="75.0" text="Ano" />
                <TableColumn fx:id="elencoColumn" prefWidth="75.0" text="Elenco" />
                <TableColumn fx:id="numTemporadasColumn" prefWidth="75.0" text="Nº temporadas" />
                <TableColumn fx:id="notaColumn" prefWidth="75.0" text="Avaliação" />
            </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>
